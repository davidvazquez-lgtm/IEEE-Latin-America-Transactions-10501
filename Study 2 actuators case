d2qd{i}=[- (7*cos(tSol(i)/2))/400 - sin(tSol(i)/10)/1000 - sin(tSol(i))/20; ySol(i,10)];

e1{i}=qd{i}-[ySol(i,1); ySol(i,3)];
e2{i}=dqd{i}-[ySol(i,2); ySol(i,4)];

Kd=-[-1.0045   -0.8645; -0.8894   -1.5385]; Kp=-[-0.7972   -0.2207; -0.1625   -0.9656];
