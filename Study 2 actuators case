eqd4 = (67312178252473169.*cos((7*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 + ySol(:,8) - 8/5).*(cos(tSol/10)/100 - (7.*sin(tSol/2))/200 + cos(tSol)/20 + ySol(:,9)).^2)/90071992547409920 - (2926616445759703.*sin((7.*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 - 8/5).*((7.*cos(tSol/2))/400 + sin(tSol/10)/1000 + sin(tSol)/20))/9007199254740992 - cos((7.*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 - 8/5).*((7.*cos(tSol/2))/400 + sin(tSol/10)/1000 + sin(tSol)/20) - (23.*cos((7.*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 + ySol(:,8) - 8/5).*((7*cos(tSol/2))/400 + sin(tSol/10)/1000 + sin(tSol)/20 - ySol(:,10)))/10 - (23.*sin((7*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 + ySol(:,8) - 8/5).*(cos(tSol/10)/100 - (7.*sin(tSol/2))/200 + cos(tSol)/20 + ySol(:,9)).^2)/10 - (67312178252473169.*sin((7.*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 + ySol(:,8) - 8/5).*((7.*cos(tSol/2))/400 + sin(tSol/10)/1000 + sin(tSol)/20 - ySol(:,10)))/90071992547409920 + (2926616445759703.*cos((7.*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 - 8/5).*(cos(tSol/10)/100 - (7.*sin(tSol/2))/200 + cos(tSol)/20).^2)/9007199254740992 - sin((7.*cos(tSol/2))/100 + sin(tSol/10)/10 + sin(tSol)/20 - 8/5).*(cos(tSol/10)/100 - (7.*sin(tSol/2))/200 + cos(tSol)/20).^2;

