Mq{i}=[((m1 + m2)*l1^2 + m2*l2^2 + 2*m2*l1*l2*cos(ySol(i,3))) (m2*l2^2 + m2*l1*l2*cos(ySol(i,3)));
    (m2*l2^2 + m2*l1*l2*cos(ySol(i,3))) m2*l2^2];

Vq{i}=[- m2*l1*l2*(2*ySol(i,2)*ySol(i,4) + ySol(i,4)^2)*sin(ySol(i,3)); 
    m2*l1*l2*ySol(i,2)^2*sin(ySol(i,3))];

