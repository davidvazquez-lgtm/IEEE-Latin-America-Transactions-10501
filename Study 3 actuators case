xl=xlabel('Time(s)','interpreter','Latex','FontSize',Fuente_tam,'FontName','Times New Roman');

subplot(2,1,2);hold on; grid on;
plot(tSol,ySol(:,3),'LineWidth',2,'color','red','LineStyle','-')
hold on; grid on; 

plot(tSol,ySol(:,8),'LineWidth',2,'color','black','LineStyle','-')
set(gca,'FontSize',Fuente_tam,'FontName','Times New Roman','box','on');
legend({'$\theta_2(t)$','$\theta_{d2}(t)$'},'interpreter','Latex','FontSize',Fuente_legend,'FontName','Times New Roman','Location','northeast');
